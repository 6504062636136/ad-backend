generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  firstName              String?
lastName               String?
name                   String?
email                  String   @unique
password               String?
phone                  String?
address                String?
dateOfBirth            String?
placeOfBirth           String?
role                   String?
status                 String?
subject                String?
degree                 String?
university             String?
city                   String?
startEndDate           String?
schoolName             String?
gradeLevel             String?
program                String?
parentName             String?
parentPhone            String?
photoUrl               String?
degreeCertificateUrl   String?
teachingLicenseUrl     String?
transcriptUrl          String?
studentCardUrl         String?
createdAt              DateTime @default(now())
updatedAt              DateTime @updatedAt

  @@map("users")
}